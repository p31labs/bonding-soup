{
  "recommendations": {
    "plugins": ["kilo-config"]
  },
  "extensions": {
    "recommendations": [
      "dbaeumer.vscode-eslint",
      "esbenp.vscode-tslint",
      "bradlc.vscode-tailwindcss"
    ]
  },
  "settings": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "typescript.tsdk": "./node_modules/typescript/lib",
    "terminal.integrated.defaultProfile.linux": "bash",
    "files.exclude": {
      "**/.git": true,
      "**/node_modules": true,
      "**/dist": true
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/dist": true,
      "**/.git": true
    }
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "P31: verify (root)",
        "type": "shell",
        "command": "npm run verify",
        "problemMatcher": ["$tsc"],
        "group": "build"
      },
      {
        "label": "P31: grant:verify",
        "type": "shell",
        "command": "npm run grant:verify",
        "problemMatcher": [],
        "group": "test"
      },
      {
        "label": "P31: grant:sync",
        "type": "shell",
        "command": "npm run grant:sync",
        "problemMatcher": [],
        "group": "build"
      },
      {
        "label": "P31: command-center",
        "type": "shell",
        "command": "npm run command-center",
        "isBackground": true,
        "problemMatcher": [],
        "group": "none"
      },
      {
        "label": "P31: startup",
        "type": "shell",
        "command": "npm run startup",
        "problemMatcher": [],
        "group": "none"
      }
    ]
  }
}
