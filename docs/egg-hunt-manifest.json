{
  "schema": "p31.quantumEggHunt/1.0.0",
  "narrative": "SIC-POVM metaphor: each entry is a rank-1 effect in a 4-vertex (K₄) product story. Rigorous POVM/SIC/qubit definitions: docs/SIC-POVM-MATHEMATICAL-APPENDIX.md. Coherence enforces the canonical 31P Larmor Hz from p31-constants.json against the dome + hub UI.",
  "coherence": {
    "larmor": {
      "fromConstants": "physics.larmorHz",
      "requireDisplay": "{value}Hz",
      "files": [
        "andromeda/04_SOFTWARE/p31ca/src/pages/dome.astro",
        "andromeda/04_SOFTWARE/p31ca/src/pages/index.astro"
      ]
    }
  },
  "entries": [
    {
      "id": "SOUP-DBG-WS",
      "operator": "parametric-superposition",
      "vertex": 1,
      "file": "soup.html",
      "require": [
        "urlParams.get('ws')",
        "urlParams.has('debug')",
        "debug: isDebug"
      ],
      "trigger": "URL phases ?debug, ?ws — C.A.R.S. lab prepared state."
    },
    {
      "id": "SOUP-ARCHIVE",
      "operator": "parametric-superposition",
      "vertex": 1,
      "file": "soup.html",
      "require": [
        "BONDING_ARCHIVE_URL"
      ],
      "trigger": "window.BONDING_ARCHIVE_URL (WCD-33) couples the lab to the archive sector."
    },
    {
      "id": "DOME",
      "operator": "povm-measurement",
      "vertex": 2,
      "file": "andromeda/04_SOFTWARE/p31ca/src/pages/dome.astro",
      "require": [
        "location.search.includes('dev=true')",
        "axe-core",
        "keyboard-shortcuts-overlay",
        "id=\"layer0\"",
        "Hold ESC for 3 seconds to disengage"
      ],
      "trigger": "/dome: dev=true superposes axe; projective measurement via / Tab Esc; Layer 0 = POVM effect."
    },
    {
      "id": "HUB-LAYER0",
      "operator": "povm-measurement",
      "vertex": 2,
      "file": "andromeda/04_SOFTWARE/p31ca/src/pages/index.astro",
      "require": [
        "id=\"trimtab-trigger\"",
        "activateLayer0",
        "Hold ESC to exit"
      ],
      "trigger": "Hub: trim control prepares Layer 0 readout; Esc = inverse measurement path."
    },
    {
      "id": "ORCH-PAGE",
      "operator": "dark-eigenstate",
      "vertex": 3,
      "file": "andromeda/04_SOFTWARE/p31ca/src/pages/orchestrator.astro",
      "require": [
        "OrchestratorDashboard",
        "../layouts/BaseLayout.astro",
        "title=\"P31 Orchestrator | Sovereign Cockpit\""
      ],
      "trigger": "/orchestrator — not coupled to the hub-landing subspace (see Pauli assertion)."
    },
    {
      "id": "ORCH-WORKER",
      "operator": "entangled-channel",
      "vertex": 3,
      "file": "andromeda/04_SOFTWARE/p31ca/src/components/OrchestratorDashboard.astro",
      "require": [
        "p31-orchestrator.trimtab-signal.workers.dev",
        "/api/orchestrator/status"
      ],
      "trigger": "Nonlocal Bell-type fetch to the orchestrator sector (CORS as deployed)."
    },
    {
      "id": "LEGACY-LATTICE-LINK",
      "operator": "weak-coupling",
      "vertex": 4,
      "file": "andromeda/04_SOFTWARE/p31ca/public/oqe-icosa.html",
      "require": [
        "<a href=\"/lattice.html\">Lattice</a>",
        "nav"
      ],
      "trigger": "Nav link from OQE Icosa sector to lattice (post–legacy-mvp-hub sunsetting)."
    },
    {
      "id": "LATTICE-WONKY",
      "operator": "weak-coupling",
      "vertex": 4,
      "file": "andromeda/04_SOFTWARE/p31ca/public/lattice.html",
      "require": [
        "id: 'mission-control'",
        "url: 'wonky.html'"
      ],
      "trigger": "lattice node graph: mission-control id → wonky static sector."
    },
    {
      "id": "ONBOARD-ARCHETYPE",
      "operator": "parametric-superposition",
      "vertex": 1,
      "file": "andromeda/04_SOFTWARE/p31ca/public/planetary-onboard.html",
      "require": [
        "const archetype",
        "elder",
        "child",
        "elder-mode",
        "child-mode",
        "data-door=\"understand\""
      ],
      "trigger": "Threshold onboard: hidden archetype anchors for tooling; ?a=child or ?welcome=kid opens Door 2 parent path. Legacy dial→connect flow lives on /connect.html?dial=…"
    },
    {
      "id": "CONNECT-DIAL",
      "operator": "parametric-superposition",
      "vertex": 1,
      "file": "andromeda/04_SOFTWARE/p31ca/public/connect.html",
      "require": [
        "_params.get('dial')",
        "_fromOnboard",
        "welcome-toast"
      ],
      "trigger": "?dial=N on /connect.html is the post-onboarding handoff signal from planetary-onboard.html. Shows welcome toast, then cleans the URL via history.replaceState."
    },
    {
      "id": "PHYSICS-FULLER-EGG",
      "operator": "weak-coupling",
      "vertex": 4,
      "file": "docs/physics-learn/index.html",
      "require": [
        "p31-egg-fuller-sr",
        "build a new model that makes the existing model obsolete"
      ],
      "trigger": "Physics Learn: Fuller quote in a screen-reader-only paragraph (accessibility Easter egg)."
    },
    {
      "id": "PHYSICS-COORD-EGG",
      "operator": "weak-coupling",
      "vertex": 4,
      "file": "docs/physics-learn/index.html",
      "require": [
        "30.7333",
        "-81.5556"
      ],
      "trigger": "Physics Learn: home latitude/longitude signature in HTML comment (not tracking)."
    },
    {
      "id": "PHYSICS-LARMOR-MS-EGG",
      "operator": "povm-measurement",
      "vertex": 2,
      "file": "docs/physics-learn/index.html",
      "require": [
        "p31-egg-larmor-ms",
        "863ms"
      ],
      "trigger": "Physics Learn: invisible pulse uses 863ms animation period (Larmor Hz as timebase; see physics.larmorHz in p31-constants.json)."
    },
    {
      "id": "SOUP-LOV-REACTION",
      "operator": "parametric-superposition",
      "vertex": 1,
      "file": "src/reactions.ts",
      "require": [
        "return 'LOV'",
        "Li–O–V letterplay"
      ],
      "trigger": "C.A.R.S.: hidden Li+V synthesis label LOV (family Easter egg; not a stoichiometry claim)."
    },
    {
      "id": "SOUP-LOV-SPAWN",
      "operator": "parametric-superposition",
      "vertex": 1,
      "file": "soup.html",
      "require": [
        "egglov",
        "spawnEggLovSandbox"
      ],
      "trigger": "soup.html: ?egglov=1 seeds Li+V near lab for LOV discovery."
    },
    {
      "id": "SIMPLEX-ORACLE-SPOON-EGG",
      "operator": "povm-measurement",
      "vertex": 2,
      "file": "simplex-v7/src/agents/runner.ts",
      "require": [
        "Empty cup, full day. Rest.",
        "context.operator_spoons === 0"
      ],
      "trigger": "ORACLE run at exactly 0/12 spoons appends spoon-theory benediction (online + offline stub)."
    }
  ],
  "assertions": [
    {
      "id": "HUB-PAULI-ORCH",
      "principle": "pauli-exclusion",
      "file": "andromeda/04_SOFTWARE/p31ca/src/data/hub-landing.json",
      "mustNotInclude": "/orchestrator"
    }
  ],
  "outOfScope": [
    "Discord slash commands (different Hilbert space)",
    "phosphorus31.org",
    "First-class hub features (Passport, connect) — not dark-sector"
  ]
}
