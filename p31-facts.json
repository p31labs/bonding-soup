{
  "schema": "p31.facts/1.0.0",
  "description": "Machine-verified invariants for this workspace. Extend when documenting externally verifiable claims; run npm run verify:facts.",
  "constants": {
    "path": "p31-constants.json",
    "requiredStringPaths": [
      "mesh.k4PersonalWorkerUrl",
      "mesh.k4CageWorkerUrl",
      "mesh.k4HubsWorkerUrl",
      "mesh.agentHubWorkerUrl",
      "mesh.orchestratorWorkerUrl",
      "mesh.passkeyApiBasePath"
    ],
    "pathsMustBeHttps": [
      "mesh.k4PersonalWorkerUrl",
      "mesh.k4CageWorkerUrl",
      "mesh.k4HubsWorkerUrl",
      "mesh.agentHubWorkerUrl",
      "mesh.orchestratorWorkerUrl"
    ],
    "organization": {
      "requiredStringPaths": ["ein", "legalName"]
    }
  },
  "pathsMustExist": [
    "p31-alignment.json",
    "p31-facts.json",
    "p31-constants.json",
    "AGENTS.md",
    "package.json",
    "packages/p31-mesh/package.json",
    "scripts/verify-facts.mjs",
    "scripts/lib/mesh-budgets.mjs",
    "scripts/print-mesh-budgets.mjs"
  ],
  "mesh": {
    "k4PersonalProbeBudgetMs": 20000,
    "glassProbeBudgetMs": 15000,
    "note": "k4Personal: verify-mesh-live SLO. glass: per-probe row ms in ecosystem-glass; P31_GLASS_BUDGET_MS overrides. P31_GLASS_BUDGET_STRICT=1 fails if any row over budget"
  },
  "forbiddenSubstringsInFiles": [
    {
      "note": "Policy files must not embed credential env assignments (see docs/AGENTIC-VIBE-INFRASTRUCTURE.md).",
      "paths": [".cursorrules", "CLAUDE.md"],
      "substrings": ["NEO4J_PASSWORD=", "NEO4J_AUTH=", "OPENAI_API_KEY=sk-"]
    }
  ]
}
