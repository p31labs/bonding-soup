---
interface Props {
  width?: number;
  height?: number;
  fill?: string;
  class?: string;
}

const { width = 24, height = 24, fill = "none", class: className } = Astro.props;
---
<svg
  viewBox="0 0 100 100"
  width={width}
  height={height}
  fill={fill}
  aria-hidden="true"
  focusable="false"
  class:list={[className]}
>
  <path
    d="M50 10 L90 85 L10 85 Z"
    stroke="var(--p31-teal)"
    stroke-width="5"
    stroke-linejoin="round"
  />
  <path
    d="M50 10 L50 60 L90 85"
    stroke="var(--p31-coral)"
    stroke-width="5"
    stroke-linejoin="round"
    opacity="0.8"
  />
  <path
    d="M50 60 L10 85"
    stroke="var(--p31-amber)"
    stroke-width="5"
    stroke-linejoin="round"
    opacity="0.6"
  />
</svg>
