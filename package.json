{
  "name": "bonding-soup",
  "version": "0.1.0",
  "description": "BONDING Soup molecular physics engine",
  "main": "dist/soup.js",
  "bin": {
    "p31": "scripts/cli/index.mjs"
  },
  "scripts": {
    "p31": "node scripts/cli/index.mjs",
    "p31:open": "node scripts/cli/index.mjs open",
    "setup": "node scripts/setup.mjs",
    "git:hooks": "node scripts/git-hooks-config.mjs",
    "git:autopush": "node scripts/git-autopush.mjs",
    "git:autopush:on": "node scripts/git-autopush.mjs on",
    "git:autopush:off": "node scripts/git-autopush.mjs off",
    "git:autopush:status": "node scripts/git-autopush.mjs status",
    "git:remotes": "node scripts/git-ensure-remotes.mjs",
    "doctor": "node scripts/p31-doctor.mjs",
    "frictionless": "node scripts/p31-frictionless.mjs",
    "gh:pr:automerge": "node scripts/gh-pr-automerge.mjs",
    "pr:ensure": "node scripts/ensure-pr.mjs",
    "pr": "node scripts/pr.mjs",
    "git:autopr:on": "node scripts/git-autopr.mjs on",
    "git:autopr:off": "node scripts/git-autopr.mjs off",
    "git:autopr:status": "node scripts/git-autopr.mjs status",
    "fix:gh": "node scripts/gh-setup-git.mjs",
    "command-center": "node scripts/p31-local-command-center.mjs",
    "build": "tsc",
    "sync:soup-bonding": "node scripts/sync-soup-to-bonding.mjs",
    "test:mock-ws": "node scripts/bonding-mock-ws-probe.mjs",
    "soup:room-scale": "node scripts/soup-room-scale.mjs",
    "test:doc-library:e2e": "node scripts/doc-library-e2e.mjs",
    "test:physics-learn:e2e": "node scripts/physics-learn-e2e.mjs",
    "test:k4market:smoke": "node scripts/k4market-smoke.mjs",
    "test:oqe-icosa:e2e": "node scripts/oqe-icosa-e2e.mjs",
    "demo": "python3 -m http.server 8080",
    "build:doc-index": "node scripts/build-doc-index.mjs",
    "sync:doc-library:p31ca": "node scripts/sync-doc-library-p31ca.mjs",
    "verify:doc-index": "node scripts/verify-doc-index.mjs",
    "docs:prep": "npm run build:doc-index",
    "dev": "tsc --watch",
    "archive:dev": "npm run dev --prefix ./wcd33-global-archive",
    "archive:deploy": "npm run deploy --prefix ./wcd33-global-archive",
    "archive:tail": "npm run tail --prefix ./wcd33-global-archive",
    "archive:typecheck": "npm run typecheck --prefix ./wcd33-global-archive",
    "sync:passport": "node scripts/sync-passport-to-p31ca.mjs",
    "verify:passport": "node scripts/verify-passport-sync.mjs",
    "verify:constants": "node scripts/verify-constants.mjs",
    "apply:constants": "node scripts/apply-constants.mjs",
    "apply:p31-style": "node scripts/apply-p31-style.mjs",
    "apply:mesh-m-first:home": "node scripts/apply-mesh-m-first-bonding-html.mjs",
    "apply:pwa:home": "node scripts/generate-bonding-pwa-icons.mjs && node scripts/apply-pwa-manifest-bonding-html.mjs",
    "generate:bonding-pwa-icons": "node scripts/generate-bonding-pwa-icons.mjs",
    "verify:p31-style": "node scripts/verify-p31-style.mjs",
    "verify:ground-truth": "npm run verify:ground-truth --prefix andromeda/04_SOFTWARE/p31ca",
    "verify:synergetic": "npm run verify:synergetic --prefix andromeda/04_SOFTWARE/p31ca",
    "verify:p31ca-contracts": "node scripts/verify-p31ca-contracts.mjs",
    "verify:monetary": "node scripts/verify-monetary.mjs",
    "verify:map-pipeline": "node scripts/verify-map-pipeline.mjs",
    "verify:k4-personal": "node scripts/verify-k4-personal.mjs",
    "p31-mesh": "node packages/p31-mesh/src/cli.mjs",
    "verify:mesh-live": "node scripts/verify-mesh-live.mjs",
    "verify:mesh": "node scripts/verify-mesh.mjs",
    "verify:egg-hunt": "node scripts/verify-egg-hunt.mjs",
    "verify:quantum-clock": "node scripts/verify-quantum-clock.mjs",
    "verify:quantum-egg": "node scripts/verify-egg-hunt.mjs",
    "verify:alignment": "node scripts/verify-alignment.mjs",
    "verify:facts": "node scripts/verify-facts.mjs",
    "p31:shipbox": "node scripts/p31-shipbox.mjs",
    "verify:shipbox": "node scripts/p31-shipbox.mjs --check",
    "verify:p31-mesh": "npm test --prefix packages/p31-mesh",
    "verify:command-center": "vitest run --config vitest.config.mjs && node scripts/command-center/server-smoke.mjs && P31_CLI_MINIMAL=1 node scripts/cli/index.mjs --version && npm run verify:p31-mesh",
    "verify:ecosystem": "node scripts/verify-ecosystem.mjs",
    "ecosystem:glass": "node scripts/ecosystem-glass.mjs",
    "mesh:budgets": "node scripts/print-mesh-budgets.mjs",
    "quantum:cloud": "node scripts/quantum-cloud-optimize.mjs",
    "pqc:verify": "npm run security:crypto --prefix andromeda/04_SOFTWARE/p31ca",
    "build:fleet-portal": "node scripts/build-fleet-portal.mjs",
    "ecosystem:plan": "node scripts/ecosystem-deploy.mjs plan",
    "ecosystem:deploy:dry": "node scripts/ecosystem-deploy.mjs dry-run",
    "ecosystem:deploy": "node scripts/ecosystem-deploy.mjs execute",
    "operator:shift-in": "node scripts/operator-shift.mjs in",
    "operator:shift-out": "node scripts/operator-shift.mjs out",
    "operator:shift-status": "node scripts/operator-shift.mjs status",
    "verify": "npm run verify:alignment && npm run verify:facts && npm run verify:shipbox && npm run verify:passport && npm run verify:constants && npm run verify:ecosystem && npm run verify:map-pipeline && npm run verify:p31-style && npm run verify:command-center && npm run verify:p31ca-contracts && npm run verify:egg-hunt && npm run build:doc-index && npm run verify:doc-index && npm run build",
    "validate:full": "bash validate-p31-full.sh",
    "verify:all": "node scripts/p31-ci.mjs",
    "p31:ci": "node scripts/p31-ci.mjs",
    "p31:ci:all": "MESH_LIVE_STRICT=1 node scripts/p31-ci.mjs --security",
    "p31:all": "node scripts/p31-all.mjs",
    "p31:ci:content": "node scripts/p31-ci.mjs --content",
    "release:check": "node scripts/p31-ci.mjs",
    "release:all": "MESH_LIVE_STRICT=1 node scripts/p31-ci.mjs --security",
    "release:local": "MESH_LIVE_STRICT=0 node scripts/p31-ci.mjs --security",
    "polish": "node scripts/p31-polish.mjs",
    "release:public": "node scripts/p31-release-public.mjs",
    "deploy:p31ca": "npm run deploy --prefix andromeda/04_SOFTWARE/p31ca",
    "inventory:cf": "node scripts/inventory-cf.mjs",
    "setup:andromeda": "cd andromeda/04_SOFTWARE && pnpm install"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@p31/mesh": "file:./packages/p31-mesh",
    "minisearch": "^6.3.0",
    "playwright": "^1.49.0",
    "typescript": "^4.9.0",
    "vitest": "^3.0.0",
    "ws": "^8.14.0"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "soup.html"
  ]
}
