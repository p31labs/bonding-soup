  },
  "exports": {
    ".": "./src/index.mjs",
    "./config": "./src/config.mjs",
    "./client": "./src/client.mjs",
    "./probe": "./src/probe.mjs",
    "./agent": "./src/agent.mjs",
    "./fleet": "./src/fleet.mjs",
    "./browser": "./src/browser.mjs"
  },
  "scripts": {
    "test": "node --test --test-reporter=spec test/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
