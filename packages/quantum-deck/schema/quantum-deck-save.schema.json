{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://p31ca.org/schema/p31.quantumDeckSave/0.1.0",
  "title": "P31 quantum deck — saved game envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "gameId", "version", "updatedAt"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "p31.quantumDeckSave/0.1.0"
    },
    "gameId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "e.g. klondike | spider-1 | quantum-klondike"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 — engine state snapshot time"
    },
    "state": {
      "type": "object",
      "description": "Opaque rules-engine payload — defined per gameId in a later revision"
    },
    "rngDisclosure": {
      "type": "string",
      "description": "Human-auditable note e.g. crypto.getRandomValues — not destiny"
    }
  }
}
