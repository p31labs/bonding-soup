# Copy keys into HA Settings → Secrets (or `secrets.yaml` — never commit).
#
# mqtt_user / mqtt_password     — Mosquitto / MQTT integration
# webhook_haptic                 — automation.p31_wearable_haptic
# webhook_calcitriol
# webhook_effexor
# webhook_safe_mode
# webhook_meltdown
# webhook_q_low
# webhook_bonding_active
#
# Worker ↔ HA (store in Cloudflare + HA only):
#   HA long-lived token         → wrangler secret put HA_TOKEN
#   HA HTTPS base URL         → wrangler secret put HA_BASE_URL
#   DEVICE_SECRET (Node Zero) — same family for optional biometric HMAC
